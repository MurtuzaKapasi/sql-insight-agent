APP_NAME=SQL Insight Agent
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL example:
# postgresql+psycopg://username:password@localhost:5432/your_db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sql_agent_db

# Groq API
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Metadata source (Excel or CSV)
METADATA_FILE=../data_model/metadata_template.csv
